# Read Access Token (JWT) de TMDb — se usa como Bearer en Authorization
TMDB_BEARER_TOKEN=replace_with_tmdb_bearer_token
# API Key (v3) — opcional si en el futuro usas ?api_key=; la app actual usa solo Bearer
TMDB_API_KEY=replace_with_tmdb_api_key

# Opcional: textos TMDb (por defecto es-ES)
# TMDB_LANGUAGE=es-ES
# Cartelera y proximos estrenos por pais (por defecto ES). Ej. US para EE.UU.
# TMDB_REGION=ES
